{
  "implementation": "rl_autoschedular_v1",

  "benchmarks_folder_path": "data/all",
  "results_dir": "results/my_experiment",

  "max_num_stores_loads": 7,
  "max_num_loops": 7,
  "max_num_load_store_dim": 7,
  "num_tile_sizes": 7,
  "vect_size_limit": 512,

  "order": [["I"], ["!", "I", "NT"], ["!", "I"], ["V", "NT"]],
  "interchange_mode": "enumerate",

  "exploration": ["entropy"],
  "init_epsilon": 0.5,

  "normalize_bounds": "max",
  "normalize_adv": "standard",
  "reuse_experience": "none",

  "bench_count": 32,
  "replay_count": 10,
  "nb_iterations": 2000,
  "ppo_epochs": 4,
  "ppo_batch_size": 64,
  "value_epochs": 0,
  "value_batch_size": 32,
  "value_coef": 0.5,
  "value_clip": false,
  "entropy_coef": 0.01,
  "lr": 0.0003,
  "truncate": 5,

  "num_pad_multiples": 3,
  "num_unroll_factors": 3,

  "hardware_auto_detect": true,
  "hardware_l1_kb": 0,
  "hardware_l2_kb": 0,
  "hardware_l3_kb": 0,
  "hardware_physical_cores": 0,
  "hardware_logical_cores": 0,
  "hardware_simd_width": 0,
  "hardware_clock_mhz": 0,

  "tags": ["v1", "hardware-aware"],
  "debug": false,
  "main_exec_data_file": ""
}
