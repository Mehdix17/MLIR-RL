{
    "implementation": "rl_autoschedular_v4",
    "benchmarks_folder_path": "data/v4_sanity",
    "results_dir": "results/test_v4_sanity",
    "max_num_stores_loads": 7,
    "max_num_loops": 7,
    "max_num_load_store_dim": 7,
    "num_tile_sizes": 7,
    "vect_size_limit": 512,
    "order": [
        ["I"],
        ["!", "I", "NT"],
        ["!", "I"],
        ["V", "NT"]
    ],
    "interchange_mode": "enumerate",
    "exploration": ["entropy"],
    "init_epsilon": 0.5,
    "normalize_bounds": "max",
    "normalize_adv": "standard",
    "reuse_experience": "none",
    "bench_count": 15,
    "replay_count": 5,
    "nb_iterations": 10,
    "ppo_epochs": 2,
    "ppo_batch_size": 16,
    "value_epochs": 0,
    "value_batch_size": 16,
    "value_coef": 0.5,
    "value_clip": false,
    "entropy_coef": 0.01,
    "lr": 0.0003,
    "truncate": 3,
    "num_pad_multiples": 3,
    "num_unroll_factors": 3,
    "hardware_auto_detect": true,
    "reward_shaping_enabled": true,
    "reward_shaping_scale": 1.0,
    "reward_shaping_clip": 2.0,
    "reward_shaping_weight_ai": 1.0,
    "reward_shaping_weight_vectorizable": 0.1,
    "reward_shaping_weight_parallel": 0.1,
    "reward_shaping_vectorization_bonus": 0.2,
    "transformer_d_model": 128,
    "transformer_nhead": 4,
    "transformer_num_layers": 2,
    "transformer_ffn_dim": 512,
    "transformer_dropout": 0.1,
    "transformer_activation": "gelu",
    "transformer_pooling": "cls",
    "transformer_use_action_history_token": false,
    "tags": ["v4", "sanity"],
    "debug": true,
    "main_exec_data_file": ""
}