{
    "implementation": "rl_autoschedular",
    "max_num_stores_loads": 7,
    "max_num_loops": 7,
    "max_num_load_store_dim": 7,
    "num_tile_sizes": 7,
    "vect_size_limit": 512,
    "order": [
        [
            "I"
        ],
        [
            "!",
            "I",
            "NT"
        ],
        [
            "!",
            "I"
        ],
        [
            "V",
            "NT"
        ]
    ],
    "interchange_mode": "enumerate",
    "exploration": [
        "entropy"
    ],
    "init_epsilon": 0.5,
    "normalize_bounds": "max",
    "normalize_adv": "standard",
    "reuse_experience": "none",
    "benchmarks_folder_path": "data/all",
    "bench_count": 10,
    "replay_count": 10,
    "nb_iterations": 1000,
    "ppo_epochs": 4,
    "ppo_batch_size": 64,
    "value_epochs": 0,
    "value_batch_size": 32,
    "value_coef": 0.5,
    "value_clip": false,
    "entropy_coef": 0.01,
    "lr": 0.0003,
    "truncate": 5,
    "tags": [
        "nn"
    ],
    "debug": false,
    "hardware_auto_detect": true,
    "main_exec_data_file": "",
    "results_dir": "results/experiment3"
}