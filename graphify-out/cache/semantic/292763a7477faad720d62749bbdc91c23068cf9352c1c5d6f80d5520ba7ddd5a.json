{"nodes": [{"id": "docs_archive_train_failures_2026_06_24_doc", "label": "docs/archive/TRAIN_FAILURES_2026_06_24.md", "file_type": "document", "source_file": "docs/archive/TRAIN_FAILURES_2026_06_24.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_archive_train_failures_2026_06_24_tiled_fusion_const_dim", "label": "TiledFusion Constant Store Dimension", "file_type": "rationale", "source_file": "docs/archive/TRAIN_FAILURES_2026_06_24.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "TiledFusion crashed when result store of a producer contained a constant literal dimension (e.g. '0'), since it was not in the loop variable mapping. Fixed by skipping constant dimensions that are not loop variables."}, {"id": "docs_archive_train_failures_2026_06_24_diagnostic_destructor_abort", "label": "C++ Diagnostic Destructor Abort", "file_type": "rationale", "source_file": "docs/archive/TRAIN_FAILURES_2026_06_24.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "C++ CollectDiagnosticsToStringScope asserts that error/warning messages are empty upon destructor execution. Warnings/remarks left in the scope abort the entire process. Fixed by isolating MLIR transformations in separate Python subprocesses."}, {"id": "docs_archive_train_failures_2026_06_24_python_signal_override", "label": "MLIR Signal Handler Override", "file_type": "rationale", "source_file": "docs/archive/TRAIN_FAILURES_2026_06_24.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "MLIR C++ context initialization overrides custom Python signal handlers. Fixed by explicitly re-registering the Python SIGABRT handler after MlirContext is initialized."}], "edges": [{"source": "docs_archive_train_failures_2026_06_24_doc", "target": "docs_archive